# CertiVerify — Backend Environment Variables
# Copy to .env and set real values before starting

# ─── Server ───
NODE_ENV=development
PORT=3001
CORS_ORIGIN=http://localhost:5173

# ─── Database (PostgreSQL) ───
DATABASE_URL=postgresql://user:password@localhost:5432/certiverify?schema=public

# ─── JWT (RSA key pair for RS256 signing) ───
JWT_PRIVATE_KEY_PATH=./keys/jwt-private.pem
JWT_PUBLIC_KEY_PATH=./keys/jwt-public.pem
JWT_ACCESS_EXPIRY=15m

# ─── Security ───
BCRYPT_ROUNDS=12
QR_HMAC_SECRET=change-this-to-a-64-char-hex-secret
ACCESS_KEY_SECRET=change-this-to-another-64-char-hex-secret
